# ==========================================
# Armazenamento Local e Datasets
# ==========================================
# Ignora a pasta storage e todos os arquivos NDJSON pesados gerados pelos crawlers
storage/
*.ndjson
*.csv
*.parquet

# (Opcional) Mantém a estrutura da pasta storage no Git sem os arquivos
!storage/.gitkeep

# ==========================================
# Banco de Dados (Prisma/Local)
# ==========================================
*.db
*.sqlite

# ==========================================
# Logs e Dumps
# ==========================================
logs/
*.log
npm-debug.log*

